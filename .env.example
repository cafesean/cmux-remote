# Copy to .env and fill in. .env is gitignored — real URLs/secrets never get committed.
# (Node 20.6+ can also load this with `node --env-file=.env server.js`.)
#
# TWO trust layers — that's why there are two secrets:
#   browser → server : SERVER_TOKEN            (who may open the web UI)
#   server  → bridge : BRIDGE_SECRET (on the Mac) MUST EQUAL CMUX_MACHINE_SECRET (here on the server)
# Pick each secret once with e.g.  openssl rand -hex 16

# ── bridge.js — run on each Mac where cmux is installed ──────────────────────
# 8799 default (8790 is a common default for other cmux bridges — avoid the clash).
BRIDGE_PORT=8799
# Long random string. The server must present this. Empty = no auth (trusted LAN only).
BRIDGE_SECRET=change-me-to-a-long-random-string
# CMUX_BIN=/Applications/cmux.app/Contents/Resources/bin/cmux

# ── server.js — the UI + proxy; run once, somewhere you trust ────────────────
PORT=8080
# Token the browser must present to use the UI. Empty = open (trusted LAN only).
SERVER_TOKEN=change-me-to-a-long-random-string

# ── machine registry (server.js) ────────────────────────────────────────────
# Simplest: one default machine via env. baseUrl = however you reach that bridge
# (LAN ip, or your own tunnel URL — see README). SECRET must match that bridge's BRIDGE_SECRET.
CMUX_MACHINE_LABEL=My Mac
CMUX_MACHINE_URL=http://192.0.2.1:8799
CMUX_MACHINE_SECRET=must-match-that-bridge-BRIDGE_SECRET

# Optional — Cloudflare Access service token, if the bridge is behind a named tunnel gated by CF Access:
# CMUX_MACHINE_ACCESS_ID=
# CMUX_MACHINE_ACCESS_SECRET=

# Multiple machines — a JSON array (extends/overrides the single default above):
# CMUX_MACHINES=[{"id":"laptop","label":"Laptop","baseUrl":"https://laptop.example.com","secret":"..."}]

# Or keep the registry in a gitignored JSON file instead:
# CMUX_CONFIG=./config.json
